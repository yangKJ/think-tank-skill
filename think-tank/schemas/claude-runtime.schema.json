{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://think-tank.dev/schemas/claude-runtime.schema.json",
  "title": "Think Tank Claude Code Minimal Runtime Result",
  "type": "object",
  "required": ["runtime", "mode", "profile", "capability", "dispatch_request", "dispatch_decision", "invocation", "recovery", "sources", "evidence", "boundaries", "quality_check"],
  "additionalProperties": false,
  "properties": {
    "runtime": {"type": "string"},
    "mode": {"type": "string", "enum": ["research", "council", "review", "strategy"]},
    "profile": {"type": "string"},
    "capability": {"type": "string"},
    "dispatch_request": {"type": "object"},
    "dispatch_decision": {"type": "object"},
    "invocation": {
      "type": "object",
      "required": ["invoked", "method", "target", "result_status"],
      "additionalProperties": true,
      "properties": {
        "invoked": {"type": "boolean"},
        "method": {"type": "string"},
        "target": {"type": "string"},
        "result_status": {"type": "string", "enum": ["success", "failed", "skipped"]}
      }
    },
    "recovery": {
      "type": "object",
      "required": ["result_recovered", "recovered_as"],
      "additionalProperties": true,
      "properties": {
        "result_recovered": {"type": "boolean"},
        "recovered_as": {"type": "array", "items": {"type": "string"}}
      }
    },
    "sources": {"type": "array", "items": {"type": "object"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "boundaries": {"type": "array", "items": {"type": "string"}},
    "quality_check": {
      "type": "object",
      "required": ["protocol_complete", "evidence_boundary_clear", "actionable"],
      "additionalProperties": false,
      "properties": {
        "protocol_complete": {"type": "boolean"},
        "evidence_boundary_clear": {"type": "boolean"},
        "actionable": {"type": "boolean"}
      }
    }
  }
}
