{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://think-tank.dev/schemas/strategy-backlog.schema.json",
  "title": "Think Tank Strategy To Backlog",
  "type": "object",
  "required": ["backlog_candidates", "sequencing", "validation_plan"],
  "additionalProperties": false,
  "properties": {
    "backlog_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "title",
          "readiness",
          "priority",
          "reason",
          "affected_area",
          "evidence",
          "acceptance_criteria",
          "non_goals",
          "dependencies",
          "risk",
          "next_owner"
        ],
        "additionalProperties": false,
        "properties": {
          "title": {"type": "string"},
          "readiness": {"type": "string", "enum": ["ready", "needs_input", "observe_only", "blocked"]},
          "priority": {"type": "string", "enum": ["P0", "P1", "P2"]},
          "reason": {"type": "string"},
          "affected_area": {"type": "array", "items": {"type": "string"}},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
          "non_goals": {"type": "array", "items": {"type": "string"}},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "risk": {"type": "array", "items": {"type": "string"}},
          "next_owner": {"type": "string"}
        }
      }
    },
    "sequencing": {"type": "array", "items": {"type": "string"}},
    "validation_plan": {"type": "array", "items": {"type": "string"}}
  }
}
