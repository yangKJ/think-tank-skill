{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://think-tank.local/schemas/research-workspace.schema.json",
  "title": "think-tank Research OS workspace contract",
  "type": "object",
  "required": ["root", "directories", "public_core_defines_contract", "local_workspace_stores_project_data"],
  "properties": {
    "root": {"type": "string", "const": ".think-tank/"},
    "directories": {
      "type": "array",
      "items": {"type": "string"},
      "contains": {"const": "runs/"}
    },
    "public_core_defines_contract": {"type": "boolean"},
    "local_workspace_stores_project_data": {"type": "boolean"}
  },
  "additionalProperties": false
}
