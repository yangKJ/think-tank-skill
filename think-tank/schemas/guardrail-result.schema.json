{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://think-tank.local/schemas/guardrail-result.schema.json",
  "title": "think-tank guardrail result",
  "type": "object",
  "required": ["gate", "status", "reason", "evidence_refs", "required_action", "fallback"],
  "properties": {
    "gate": {"type": "string"},
    "status": {"type": "string", "enum": ["pass", "fail", "blocked", "needs_user_confirmation"]},
    "reason": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "required_action": {"type": "string"},
    "fallback": {"type": "string"}
  },
  "additionalProperties": false
}
