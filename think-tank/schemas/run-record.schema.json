{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://think-tank.local/schemas/run-record.schema.json",
  "title": "think-tank 2.0 run record",
  "type": "object",
  "required": [
    "run_id",
    "created_at",
    "user_intent",
    "selected_mode",
    "selected_recipe",
    "selected_profiles",
    "selected_capabilities",
    "runtime_provenance",
    "provider_invocation_ledger",
    "evidence_refs",
    "conclusions",
    "disagreements",
    "risks",
    "next_actions",
    "post_run_curation",
    "memory_runtime",
    "quality_check"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "created_at": {"type": "string"},
    "user_intent": {"type": "string"},
    "selected_mode": {"type": "string"},
    "selected_recipe": {"type": "string"},
    "selected_profiles": {"type": "array", "items": {"type": "string"}},
    "selected_capabilities": {"type": "array", "items": {"type": "string"}},
    "runtime_provenance": {"type": "object"},
    "provider_invocation_ledger": {"$ref": "provider-invocation-ledger.schema.json"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "conclusions": {"type": "array", "items": {"type": "string"}},
    "disagreements": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "post_run_curation": {"type": "object"},
    "memory_runtime": {"$ref": "memory-runtime.schema.json"},
    "quality_check": {"type": "object"}
  },
  "additionalProperties": false
}
