{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://think-tank.dev/schemas/input.schema.json",
  "title": "Think Tank Input",
  "type": "object",
  "required": ["task"],
  "additionalProperties": false,
  "properties": {
    "task": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["research", "council", "review", "strategy", "auto"],
      "default": "auto"
    },
    "context": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "constraints": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "success_criteria": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "evidence_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": {
          "type": "string",
          "enum": ["allowed", "disallowed", "required"]
        },
        "local_sources": {
          "type": "string",
          "enum": ["allowed", "required"]
        },
        "citations": {
          "type": "string",
          "enum": ["optional", "required"]
        }
      }
    },
    "output_preference": {
      "type": "string",
      "enum": ["report", "plan", "review", "decision", "checklist"]
    }
  }
}
