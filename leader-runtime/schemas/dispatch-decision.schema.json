{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/dispatch-decision.schema.json",
  "title": "Leader Runtime Dispatch Decision",
  "type": "object",
  "required": [
    "leader_id",
    "task_shape",
    "delegation_needed",
    "reason",
    "selected_path",
    "fallback_path",
    "verification_status",
    "selected_experts",
    "boundaries"
  ],
  "properties": {
    "leader_id": {"type": "string", "minLength": 1},
    "task_shape": {"type": "string", "enum": ["simple", "focused", "multi_domain", "adversarial", "execution_heavy"]},
    "delegation_needed": {"type": "boolean"},
    "reason": {"type": "string", "minLength": 1},
    "selected_path": {"type": "string", "enum": ["leader_direct", "structured_council", "expert_dispatch", "mixed_orchestration", "single_agent_multi_profile_fallback"]},
    "fallback_path": {"type": "string", "enum": ["protocol_only", "leader_direct", "single_agent_multi_profile_fallback"]},
    "verification_status": {"type": "string", "enum": ["planned", "specified", "verified_partial", "verified"]},
    "selected_experts": {"type": "array", "items": {"type": "string"}},
    "candidate_experts": {"type": "array", "items": {"type": "string"}},
    "selected_profiles": {"type": "array", "items": {"type": "string"}},
    "required_capabilities": {"type": "array", "items": {"type": "string"}},
    "boundaries": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
