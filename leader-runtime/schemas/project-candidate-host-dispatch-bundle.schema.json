{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/project-candidate-host-dispatch-bundle.schema.json",
  "title": "Leader Runtime Project Candidate Host Dispatch Bundle",
  "type": "object",
  "required": [
    "bundle_id",
    "adapter",
    "adapter_version",
    "dispatch_status",
    "request_count",
    "dispatch_requests",
    "boundaries"
  ],
  "properties": {
    "bundle_id": {"type": "string", "minLength": 1},
    "adapter": {"type": "string", "minLength": 1},
    "adapter_version": {"type": "string", "minLength": 1},
    "dispatch_status": {"type": "string", "enum": ["not_applicable", "blocked", "ready_for_host_dispatch"]},
    "request_count": {"type": "integer", "minimum": 0},
    "dispatch_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "candidate_agent_id",
          "candidate_name",
          "dispatch_status",
          "host_payload",
          "invoked"
        ],
        "properties": {
          "task_id": {"type": "string", "minLength": 1},
          "candidate_agent_id": {"type": "string", "minLength": 1},
          "candidate_name": {"type": "string", "minLength": 1},
          "dispatch_status": {"type": "string", "enum": ["ready_for_host_dispatch", "blocked"]},
          "host_payload": {"type": "object"},
          "invoked": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "boundaries": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
