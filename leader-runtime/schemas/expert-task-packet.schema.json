{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/expert-task-packet.schema.json",
  "title": "Leader Runtime Expert Task Packet",
  "type": "object",
  "required": [
    "task_id",
    "leader_id",
    "expert_id",
    "mapped_role",
    "objective",
    "task_scope",
    "required_capabilities",
    "input_context",
    "deliverables",
    "acceptance_checks",
    "independence_boundary",
    "fallback_rule"
  ],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "leader_id": {"type": "string", "minLength": 1},
    "expert_id": {"type": "string", "minLength": 1},
    "mapped_role": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "task_scope": {"type": "string", "minLength": 1},
    "required_capabilities": {"type": "array", "items": {"type": "string"}},
    "input_context": {"type": "array", "items": {"type": "string"}},
    "deliverables": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "acceptance_checks": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "independence_boundary": {"type": "string", "minLength": 1},
    "fallback_rule": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
