{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/project-candidate-invocation-gate.schema.json",
  "title": "Leader Runtime Project Candidate Invocation Gate",
  "type": "object",
  "required": [
    "gate_id",
    "allow_invocation",
    "runtime_support",
    "decision_status",
    "candidate_decisions",
    "boundaries"
  ],
  "properties": {
    "gate_id": {"type": "string", "minLength": 1},
    "allow_invocation": {"type": "boolean"},
    "runtime_support": {"type": "string", "enum": ["not_verified", "specified", "verified_partial", "verified"]},
    "decision_status": {"type": "string", "enum": ["not_applicable", "blocked", "ready_uninvoked"]},
    "candidate_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_agent_id", "task_id", "decision", "reason", "invoked"],
        "properties": {
          "candidate_agent_id": {"type": "string", "minLength": 1},
          "task_id": {"type": "string", "minLength": 1},
          "decision": {"type": "string", "enum": ["blocked", "ready_uninvoked"]},
          "reason": {"type": "string", "minLength": 1},
          "invoked": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "boundaries": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
