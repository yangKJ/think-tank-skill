{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/candidate-selection-result.schema.json",
  "title": "Leader Runtime Candidate Selection Result",
  "type": "object",
  "required": [
    "selection_id",
    "policy_id",
    "project_id",
    "selected_count",
    "rejected_count",
    "selected_candidates",
    "promotion_target",
    "review_required",
    "boundaries"
  ],
  "properties": {
    "selection_id": {"type": "string", "minLength": 1},
    "policy_id": {"type": "string", "minLength": 1},
    "project_id": {"type": "string", "minLength": 1},
    "selected_count": {"type": "integer", "minimum": 0},
    "rejected_count": {"type": "integer", "minimum": 0},
    "selected_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "name", "source_path", "source_domain", "authority_scope_hint", "selection_reasons", "conversion_status"],
        "properties": {
          "agent_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "source_path": {"type": "string", "minLength": 1},
          "source_domain": {"type": "string", "minLength": 1},
          "authority_scope_hint": {"type": "string", "enum": ["analysis", "execution", "review", "strategy"]},
          "tools": {"type": "array", "items": {"type": "string"}},
          "selection_reasons": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "conversion_status": {"type": "string", "enum": ["candidate", "reviewed", "rejected", "promoted"]}
        },
        "additionalProperties": false
      }
    },
    "promotion_target": {"type": "string", "enum": ["project_team_pack", "manual_review"]},
    "review_required": {"type": "boolean"},
    "boundaries": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
