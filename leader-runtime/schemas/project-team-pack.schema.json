{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/project-team-pack.schema.json",
  "title": "Leader Runtime Project Team Pack",
  "type": "object",
  "required": [
    "pack_id",
    "project_id",
    "inherits_from_registry",
    "include_experts",
    "exclude_experts",
    "project_tags",
    "capability_overrides",
    "boundaries"
  ],
  "properties": {
    "pack_id": {"type": "string", "minLength": 1},
    "project_id": {"type": "string", "minLength": 1},
    "inherits_from_registry": {"type": "string", "minLength": 1},
    "include_experts": {"type": "array", "items": {"type": "string"}},
    "include_candidate_agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "name", "source_platform", "source_path", "conversion_status"],
        "properties": {
          "agent_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "source_platform": {"type": "string", "enum": ["claude-code"]},
          "source_path": {"type": "string", "minLength": 1},
          "conversion_status": {"type": "string", "enum": ["candidate", "reviewed", "rejected", "promoted"]}
        },
        "additionalProperties": false
      }
    },
    "candidate_source_policy": {"type": ["string", "null"]},
    "exclude_experts": {"type": "array", "items": {"type": "string"}},
    "project_tags": {"type": "array", "items": {"type": "string"}},
    "capability_overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"}
      }
    },
    "acceptance_overrides": {
      "type": "object",
      "properties": {
        "required_checks": {"type": "array", "items": {"type": "string"}},
        "retry_limit": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "boundaries": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
