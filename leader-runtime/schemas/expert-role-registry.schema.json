{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/expert-role-registry.schema.json",
  "title": "Leader Runtime Expert Role Registry",
  "type": "object",
  "required": ["registry_id", "owner", "scope", "experts"],
  "properties": {
    "registry_id": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "enum": ["global", "project"]},
    "inherits_from": {"type": ["string", "null"]},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "experts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "expert_id",
          "label",
          "owner_layer",
          "mapped_roles",
          "specialties",
          "supported_modes",
          "preferred_intents",
          "capability_affinity",
          "dispatch_style",
          "authority_scope",
          "availability_status",
          "project_tags",
          "boundaries"
        ],
        "properties": {
          "expert_id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "owner_layer": {"type": "string", "enum": ["global", "project"]},
          "mapped_roles": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "specialties": {"type": "array", "items": {"type": "string"}},
          "supported_modes": {"type": "array", "items": {"type": "string", "enum": ["research", "council", "review", "strategy"]}, "minItems": 1},
          "preferred_intents": {"type": "array", "items": {"type": "string"}},
          "capability_affinity": {"type": "array", "items": {"type": "string"}},
          "dispatch_style": {"type": "string", "enum": ["specialist_subagent", "worker_prompt", "fallback_only"]},
          "authority_scope": {"type": "string", "enum": ["analysis", "execution", "review", "strategy", "mixed"]},
          "availability_status": {"type": "string", "enum": ["verified", "verified_partial", "specified", "planned"]},
          "project_tags": {"type": "array", "items": {"type": "string"}},
          "boundaries": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
