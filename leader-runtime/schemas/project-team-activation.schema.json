{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/project-team-activation.schema.json",
  "title": "Leader Runtime Project Team Activation",
  "type": "object",
  "required": [
    "activation_id",
    "project_id",
    "pack_id",
    "active_count",
    "global_experts",
    "candidate_agents",
    "dispatch_roster",
    "verification_status",
    "boundaries"
  ],
  "properties": {
    "activation_id": {"type": "string", "minLength": 1},
    "project_id": {"type": "string", "minLength": 1},
    "pack_id": {"type": "string", "minLength": 1},
    "active_count": {"type": "integer", "minimum": 0},
    "global_experts": {"type": "array", "items": {"type": "string"}},
    "candidate_agents": {"type": "array", "items": {"type": "string"}},
    "dispatch_roster": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["roster_id", "name", "source", "authority_scope", "dispatch_status"],
        "properties": {
          "roster_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "source": {"type": "string", "enum": ["global_registry", "project_candidate"]},
          "authority_scope": {"type": "string", "minLength": 1},
          "dispatch_status": {"type": "string", "enum": ["available", "promoted_uninvoked", "excluded"]},
          "source_path": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "verification_status": {"type": "string", "enum": ["specified", "verified_partial", "verified"]},
    "boundaries": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "additionalProperties": false
}
