{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leader-runtime.local/schemas/project-candidate-task-packet.schema.json",
  "title": "Leader Runtime Project Candidate Task Packet",
  "type": "object",
  "required": [
    "task_id",
    "leader_id",
    "candidate_agent_id",
    "candidate_name",
    "source_path",
    "objective",
    "task_scope",
    "required_capabilities",
    "input_context",
    "deliverables",
    "acceptance_checks",
    "dispatch_status",
    "invocation_boundary",
    "fallback_rule"
  ],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "leader_id": {"type": "string", "minLength": 1},
    "candidate_agent_id": {"type": "string", "minLength": 1},
    "candidate_name": {"type": "string", "minLength": 1},
    "source_path": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "task_scope": {"type": "string", "minLength": 1},
    "required_capabilities": {"type": "array", "items": {"type": "string"}},
    "input_context": {"type": "array", "items": {"type": "string"}},
    "deliverables": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "acceptance_checks": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "dispatch_status": {"type": "string", "enum": ["planned_uninvoked", "blocked", "invoked"]},
    "invocation_boundary": {"type": "string", "minLength": 1},
    "fallback_rule": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
